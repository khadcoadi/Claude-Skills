{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.4",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "TextBlock",
              "text": "⚡",
              "size": "large"
            }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "PIXEL",
              "weight": "bolder",
              "size": "small",
              "color": "good",
              "spacing": "none"
            },
            {
              "type": "TextBlock",
              "text": "New Lead Enriched",
              "weight": "bolder",
              "size": "medium",
              "spacing": "none"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${full_name} — ${company}",
                  "weight": "bolder",
                  "size": "large",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "${city}, ${state} · ${venue_type} · ⭐ ${google_rating}",
                  "spacing": "small",
                  "isSubtle": true,
                  "wrap": true
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${icp_fit}",
                  "weight": "bolder",
                  "size": "medium",
                  "color": "${fit_color}",
                  "horizontalAlignment": "right"
                },
                {
                  "type": "TextBlock",
                  "text": "${icp_score}/100",
                  "size": "small",
                  "horizontalAlignment": "right",
                  "spacing": "none"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Source", "value": "${lead_source} — ${campaign}" },
        { "title": "Visits", "value": "${visits_summary}" },
        { "title": "Locations", "value": "${location_count}" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "\u201c${lead_message}\u201d",
      "wrap": true,
      "size": "medium",
      "isSubtle": true,
      "spacing": "medium"
    },
    {
      "type": "TextBlock",
      "text": "HOOKS",
      "weight": "bolder",
      "size": "small",
      "spacing": "medium",
      "separator": true
    },
    {
      "type": "TextBlock",
      "text": "${hooks_formatted}",
      "wrap": true,
      "size": "small"
    },
    {
      "type": "Container",
      "style": "${action_style}",
      "items": [
        {
          "type": "TextBlock",
          "text": "${recommended_action}",
          "wrap": true,
          "weight": "bolder"
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "Enriched: ${enrichment_timestamp}",
      "size": "small",
      "isSubtle": true,
      "spacing": "medium"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Open in CRM",
      "url": "https://crm.zoho.com/crm/org45247585/tab/Leads/${lead_id}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "\ud83d\udcde Call",
      "url": "tel:${phone}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "\ud83c\udf10 View Venue",
      "url": "${venue_url}"
    },
    {
      "type": "Action.OpenUrl",
      "title": "\ud83d\udcf0 ${article_title}",
      "url": "${article_url}"
    }
  ]
}
