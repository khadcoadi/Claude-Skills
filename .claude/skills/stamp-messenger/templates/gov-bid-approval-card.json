{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.4",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Gov bid — approval required",
                  "size": "small",
                  "isSubtle": true,
                  "spacing": "none"
                },
                {
                  "type": "TextBlock",
                  "text": "${title}",
                  "weight": "bolder",
                  "size": "medium",
                  "wrap": true,
                  "spacing": "small"
                },
                {
                  "type": "TextBlock",
                  "text": "${sol_number} · ${agency}",
                  "size": "small",
                  "isSubtle": true,
                  "wrap": true,
                  "spacing": "none"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "verticalContentAlignment": "center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${match_score}",
                  "weight": "bolder",
                  "size": "extraLarge",
                  "color": "${score_color}",
                  "horizontalAlignment": "right"
                },
                {
                  "type": "TextBlock",
                  "text": "${status_badge}",
                  "size": "small",
                  "color": "${score_color}",
                  "horizontalAlignment": "right",
                  "spacing": "none",
                  "weight": "bolder"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "FactSet",
      "spacing": "small",
      "facts": [
        { "title": "Location", "value": "${location}" },
        { "title": "Due", "value": "${deadline} · ${days_remaining}" },
        { "title": "Set-aside", "value": "${set_aside}" },
        { "title": "System type", "value": "${type_of_system}" },
        { "title": "Submission", "value": "${bid_submission_style}" },
        { "title": "Site visit", "value": "${mandatory_site_visit}" }
      ]
    },
    {
      "type": "TextBlock",
      "text": "SCOPE",
      "weight": "bolder",
      "size": "small",
      "spacing": "medium",
      "separator": true
    },
    {
      "type": "TextBlock",
      "text": "${scope_summary}",
      "wrap": true,
      "size": "small"
    },
    {
      "type": "TextBlock",
      "text": "PROGRAMMING & CUSTOM WORK",
      "weight": "bolder",
      "size": "small",
      "spacing": "medium",
      "separator": true
    },
    {
      "type": "TextBlock",
      "text": "${programming_scope}",
      "wrap": true,
      "size": "small"
    },
    {
      "type": "TextBlock",
      "text": "FLAGS",
      "weight": "bolder",
      "size": "small",
      "spacing": "medium",
      "separator": true
    },
    {
      "type": "TextBlock",
      "text": "${detailed_flags}",
      "wrap": true,
      "size": "small"
    },
    {
      "type": "TextBlock",
      "text": "POC: ${poc_name} · ${poc_email}",
      "size": "small",
      "isSubtle": true,
      "spacing": "small"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Approve — push to CRM",
      "data": {
        "action": "approve",
        "sol_num": "${sol_number}",
        "push_payload": "${push_payload_json}"
      }
    },
    {
      "type": "Action.OpenUrl",
      "title": "View on SAM.gov",
      "url": "https://sam.gov/opp/${notice_id}/view"
    },
    {
      "type": "Action.Submit",
      "title": "Skip",
      "data": { "action": "skip", "sol_num": "${sol_number}" }
    }
  ]
}
